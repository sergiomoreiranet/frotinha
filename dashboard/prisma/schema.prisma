generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Opm {
  id               String            @id @default(cuid())
  codigo           String            @unique
  nome             String
  municipio        String?
  macroComando     String?
  metas            QffMeta[]
  veiculos         Veiculo[]
  veiculosAjuste   VeiculoAjuste[]
  veiculosSnapshot VeiculoSnapshot[]
}

model QffMeta {
  id               String @id @default(cuid())
  opmCodigo        String
  grupo            String
  programa         String
  quantidadeFixada Int
  opm              Opm    @relation(fields: [opmCodigo], references: [codigo])

  @@unique([opmCodigo, grupo, programa])
}

model Veiculo {
  id                  String    @id @default(cuid())
  patrimonio          String    @unique
  placa               String
  marcaModelo         String
  ano                 Int
  grupo               String
  programa            String
  opmCodigo           String
  prefixo             String?
  situacao            String? // Maintain this one, can act as statusUso
  // New specific fields
  pertence            String?
  informacaoAdicional String?
  tipoTracao          String?
  cambio              String?
  licenciamento       String?
  apresentacao        String?
  estribo             String?
  radio               String?
  grafismo            String?
  monocela            String?
  ultimaRevisao       DateTime?
  localizacao         String?

  opm Opm @relation(fields: [opmCodigo], references: [codigo])
}

model VeiculoAjuste {
  id                  String    @id @default(cuid())
  patrimonio          String    @unique
  placa               String
  marcaModelo         String
  ano                 Int
  grupo               String
  programa            String
  opmCodigo           String
  prefixo             String?
  situacao            String?
  // New specific fields
  pertence            String?
  informacaoAdicional String?
  tipoTracao          String?
  cambio              String?
  licenciamento       String?
  apresentacao        String?
  estribo             String?
  radio               String?
  grafismo            String?
  monocela            String?
  ultimaRevisao       DateTime?
  localizacao         String?

  alteradoEm DateTime?
  opm        Opm       @relation(fields: [opmCodigo], references: [codigo])
}

model VeiculoSnapshot {
  id                  String    @id @default(cuid())
  mesReferencia       String // Formato: YYYY-MM
  patrimonio          String
  placa               String?
  marcaModelo         String?
  ano                 Int?
  grupo               String?
  programa            String?
  opmCodigo           String
  prefixo             String?
  situacao            String?
  // New specific fields
  pertence            String?
  informacaoAdicional String?
  tipoTracao          String?
  cambio              String?
  licenciamento       String?
  apresentacao        String?
  estribo             String?
  radio               String?
  grafismo            String?
  monocela            String?
  ultimaRevisao       DateTime?
  localizacao         String?

  opm Opm @relation(fields: [opmCodigo], references: [codigo])

  @@unique([mesReferencia, patrimonio])
  @@index([mesReferencia])
}

model VeiculoEmprestimo {
  id            String  @id @default(cuid())
  placa         String  @unique
  patrimonio    String?
  prefixo       String?
  marcaModelo   String?
  ano           String?
  cor           String?
  pertence      String?
  observacoes   String? @db.Text
  detentorAtual String?
  unidade       String?

  // New specific fields
  motivo              String?
  informacaoAdicional String?
  tipoTracao          String?
  cambio              String?
  licenciamento       String?
  apresentacao        String?
  estribo             String?
  radio               String?
  grafismo            String?
  monocela            String?
  ultimaRevisao       DateTime?
  localizacao         String?

  statusUso String  @default("DISPONIVEL")
  ativo     Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  emprestimos Emprestimo[]
}

model Emprestimo {
  id            String    @id @default(cuid())
  veiculoId     String
  dataRetirada  DateTime  @default(now())
  quemRetirou   String
  kmRetirada    Int?
  dataDevolucao DateTime?
  quemEntregou  String?
  kmDevolucao   Int?
  observacao    String?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  veiculo VeiculoEmprestimo @relation(fields: [veiculoId], references: [id])
}
